graph TB
    subgraph "guard — Security Stack (1,221 lines)"
        INPUT[Incoming Request] --> ENFORCER[guard/enforcer.py<br/>Coordinator]

        ENFORCER --> |"1"| BASIN[guard/basin.py<br/>Basin Classification]
        ENFORCER --> |"2"| FIREWALL[guard/firewall.py<br/>Injection Defense]
        ENFORCER --> |"3"| SANDBOX[guard/sandbox.py<br/>Runtime Isolation]
        ENFORCER --> |"4"| DBAD[guard/__init__.py<br/>DBAD Ethics]

        BASIN --> |"capability analysis"| RESULT{Decision}
        FIREWALL --> |"pattern + entropy"| RESULT
        SANDBOX --> |"path + command"| RESULT
        DBAD --> |"intent basin"| RESULT

        RESULT --> |"allow"| ALLOW[Execute]
        RESULT --> |"flag"| FLAG[Log + Allow]
        RESULT --> |"gate"| GATE[Human Approval Required]
        RESULT --> |"deny"| DENY[Blocked]

        BASIN --> KH[K-History Tracker<br/>Trust builds over time]
        BASIN --> AG[AccessGate<br/>Accountability, not blocking]

        subgraph "Basin Examples"
            B1["fix auth bug → ALLOW"]
            B2["red team audit → ALLOW<br/>(defensive context)"]
            B3["phishing email → DENY<br/>(harmful basin)"]
            B4["ignore instructions → DENY<br/>(injection detected)"]
        end
    end

    style ENFORCER fill:#8b2500,color:#fff
    style DENY fill:#ff0000,color:#fff
    style ALLOW fill:#28a745,color:#fff
    style GATE fill:#c9a84c,color:#1a1410
